# ====================================================
# Cấu hình AI Service cho Render
# ====================================================
# Mặc định: sẽ dùng model train5 từ thư mục models/train5/weights/best.pt
# Nếu file không tồn tại, fallback sang yolov8n.pt

# Tùy chỉnh đường dẫn model (optional - để trống sẽ dùng mặc định)
# MODEL_DETECT_PATH=models/train5/weights/best.pt
# MODEL_CLASSIFY_PATH=models/train5/weights/best.pt
# MODEL_COCO_PATH=yolov8n.pt

# Tùy chỉnh YAML files (optional)
# YAML_DETECT_PATH=mydata.yaml
# YAML_CLASSIFY_PATH=mydata.yaml
