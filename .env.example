# ====================================================
# Cấu hình AI Service cho Render
# ====================================================
# Xóa dấu # khi deploy thực tế, điền giá trị cần thiết

# Port (Render tự cấp qua PORT env, không cần sửa)
# PORT=8000

# ====================================================
# CÁC OPTION CHỌN MODEL (chọn 1 trong 3 phương án)
# ====================================================

# OPTION 1: Dùng model custom từ repo (nên dùng nếu model nhỏ < 100MB)
# Giá trị: đường dẫn tương đối từ thư mục hiện tại
# MODEL_DETECT_PATH=models/train5/weights/best.pt
# MODEL_CLASSIFY_PATH=models/train5/weights/best.pt
# MODEL_USE_DEFAULT=false

# OPTION 2: Dùng model mặc định nhẹ từ ultralytics (khuyên dùng trên free tier)
# Cách này: Ultralytics tự download model khi chạy lần đầu
MODEL_USE_DEFAULT=true

# OPTION 3: Dùng URL tới model file trên cloud storage (nếu bạn upload model riêng)
# MODEL_DETECT_PATH=https://your-cloud-storage-url/best.pt
# MODEL_CLASSIFY_PATH=https://your-cloud-storage-url/best.pt
# MODEL_USE_DEFAULT=false

# ====================================================
# Other config (optional)
# ====================================================
# Confidence threshold cho model detection (0.0 - 1.0)
# CONF_THRESHOLD=0.6

# Debug mode (true/false)
# DEBUG=false
